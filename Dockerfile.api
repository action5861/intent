# [배포 #1] Railway API 서버용 Dockerfile (monorepo 루트 기준)
FROM node:20-alpine
WORKDIR /app

RUN npm install -g pnpm@9.0.0

# 빌드 타임 더미 DATABASE_URL — prisma generate/postinstall이 DB 없이 실행되도록
# 실제 DATABASE_URL은 컨테이너 시작 시 Railway가 환경변수로 주입
ENV DATABASE_URL="postgresql://dummy:dummy@localhost:5432/dummy"

# 의존성 레이어 캐시 최적화 — 소스 변경 시 재설치 방지
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/api/package.json apps/api/
RUN pnpm install --frozen-lockfile --filter api...

# 소스 복사 및 빌드
COPY apps/api apps/api
RUN cd apps/api && npx prisma generate
RUN cd apps/api && pnpm run build

EXPOSE 4000

# 시작 시 마이그레이션 자동 적용 후 서버 기동
CMD ["sh", "-c", "cd apps/api && npx prisma migrate deploy && node dist/main.js"]
