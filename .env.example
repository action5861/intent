# [배포 #7] Railway 배포 시 설정해야 할 환경변수 목록
# Railway 대시보드 > 서비스 > Variables 탭에서 직접 입력
# 이 파일은 예시용이며 실제 값을 절대 커밋하지 마세요

# ==================== 필수 ====================

# PostgreSQL (Railway Postgres 플러그인 사용 시 자동 주입됨)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Redis (Railway Redis 플러그인 사용 시 자동 주입됨)
REDIS_HOST=your-redis-host
REDIS_PORT=6379

# JWT — 최소 64자 이상 랜덤 문자열
# 생성 명령어: openssl rand -base64 64
JWT_SECRET=최소64자랜덤문자열
JWT_EXPIRES_IN=7d

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# CORS — 프론트엔드 Railway 도메인 (슬래시 없이)
FRONTEND_URL=https://your-web-service.up.railway.app

# reCAPTCHA v3 서버 시크릿 (Google reCAPTCHA 콘솔에서 발급)
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# 반드시 production으로 설정
NODE_ENV=production

# ==================== 어드민 ====================

ADMIN_USERNAME=admin
ADMIN_PASSWORD=강력한비밀번호_특수문자포함

# ==================== 선택 ====================

# API 서버 포트 (기본 4000, Railway는 PORT 자동 주입 — 보통 생략 가능)
API_PORT=4000
