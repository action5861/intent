# ==============================================================================
# 🚨 INTENDEX PROJECT ENVIRONMENT VARIABLES TEMPLATE 🚨
# ==============================================================================
# 이 파일은 버전 관리에 포함되는 템플릿 파일입니다. (.env.example)
# 실제 값은 절대 이 파일에 적지 마시고, 로컬 환경의 .env 파일에 작성하세요!
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Global / App Configuration
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
API_PORT=4000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# ------------------------------------------------------------------------------
# 2. Database Configuration (PostgreSQL / MySQL / MongoDB 등)
# ------------------------------------------------------------------------------
# Database Connection URL (포맷: db_type://user:password@host:port/db_name)
DATABASE_URL="postgresql://[USER]:[PASSWORD]@localhost:5432/intendex_db?schema=public"
DB_HOST=localhost
DB_PORT=5432
DB_USER=root
DB_PASSWORD=
DB_NAME=intendex_db

# ------------------------------------------------------------------------------
# 3. Authentication / Security (JWT, Session 등)
# ------------------------------------------------------------------------------
# 무작위로 생성된 강력한 비밀키를 사용하세요
JWT_SECRET="your-super-secret-jwt-key-change-it-in-production"
JWT_EXPIRES_IN="7d"

# ------------------------------------------------------------------------------
# 4. Third-Party API Keys (Google Gemini, etc.)
# ------------------------------------------------------------------------------
# Google Gemini API Key
GEMINI_API_KEY="your-gemini-api-key-here"

# 기타 연동 API 키
# STRIPE_API_KEY="sk_test_..."
# AWS_ACCESS_KEY_ID="..."
# AWS_SECRET_ACCESS_KEY="..."
